#!/usr/bin/env python3
import json
import os
import re
import signal
import shlex
import shutil
import subprocess
import sys
import time
import unicodedata
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Any, Dict, List, Tuple

TOKEN_URL = 'https://accounts.spotify.com/api/token'
API_BASE = 'https://api.spotify.com/v1'
URI_RE = re.compile(r'^spotify:(track|album|playlist):([A-Za-z0-9]+)$')
SUPPORTED_CACHE_FORMATS = {'mp3', 'flac', 'ogg'}
DEFAULT_CACHE_FORMAT = 'mp3'
DEFAULT_CACHE_BITRATE = '192k'
DEFAULT_MIN_ACCESS_TTL_SECONDS = 600
CACHE_EXTENSION = {
    'mp3': '.mp3',
    'flac': '.flac',
    'ogg': '.ogg',
}
KNOWN_AUDIO_SUFFIXES = {'.mp3', '.flac', '.ogg', '.m4a', '.aac'}
KNOWN_IMAGE_SUFFIXES = {'.jpg', '.jpeg', '.png', '.webp'}
MANIFEST_NAME = '.spotify-import.json'
IMPORTING_DIR_NAME = '.importing'
MIN_VALID_BYTES = 20000
MIN_VALID_IMAGE_BYTES = 1024
PCM_SAMPLE_RATE = 44100
PCM_CHANNELS = 2
PCM_BYTES_PER_SAMPLE = 2
PCM_BYTES_PER_SECOND = PCM_SAMPLE_RATE * PCM_CHANNELS * PCM_BYTES_PER_SAMPLE


def fail(message: str, code: int = 1) -> None:
    print(message, file=sys.stderr)
    sys.exit(code)


def normalize_spotify_uri(value: str) -> str:
    text = str(value or '').strip()
    match = URI_RE.match(text)
    if match:
        return f"spotify:{match.group(1)}:{match.group(2)}"

    parsed = urllib.parse.urlparse(text)
    if parsed.scheme not in {'http', 'https'}:
        fail('Spotify URI/URL is invalid')
    if parsed.netloc not in {'open.spotify.com', 'www.open.spotify.com'}:
        fail('Spotify URL must use open.spotify.com')
    parts = [chunk for chunk in parsed.path.split('/') if chunk]
    if len(parts) < 2:
        fail('Spotify URL path is invalid')
    media_type = parts[0].lower()
    media_id = parts[1]
    if media_type not in {'track', 'album', 'playlist'} or not re.fullmatch(r'[A-Za-z0-9]+', media_id):
        fail('Spotify URL must be track/album/playlist')
    return f'spotify:{media_type}:{media_id}'


def slug(value: str, fallback: str = 'item') -> str:
    text = unicodedata.normalize('NFKC', str(value or ''))
    text = text.replace('\x00', '')
    text = text.replace('/', '_').replace('\\', '_')
    text = re.sub(r'[\r\n\t]+', ' ', text)
    text = re.sub(r'[:*?"<>|]+', '_', text)
    text = re.sub(r'\s+', ' ', text).strip()
    text = text.strip(' .')
    return text or fallback


def capture_device_name(base_name: str) -> str:
    base = re.sub(r'[^A-Za-z0-9 _-]+', '', str(base_name or '')).strip() or 'musicbox'
    base = re.sub(r'\s+', ' ', base).strip()
    # Keep room for "-12345" suffix and stay under common device name limits.
    base = base[:26].rstrip(' -') or 'musicbox'
    suffix = f'-{os.getpid() % 100000:05d}'
    return f'{base}{suffix}'


def normalize_cache_format(value: str) -> str:
    fmt = str(value or '').strip().lower() or DEFAULT_CACHE_FORMAT
    if fmt not in SUPPORTED_CACHE_FORMATS:
        fail(f'Unsupported cache format "{fmt}". Use one of: {", ".join(sorted(SUPPORTED_CACHE_FORMATS))}')
    return fmt


def normalize_bitrate(value: str, fallback: str = DEFAULT_CACHE_BITRATE) -> str:
    raw = str(value or '').strip().lower() or fallback
    if not re.fullmatch(r'[1-9][0-9]{1,3}k', raw):
        fail(f'Invalid bitrate "{raw}". Use values like 128k, 160k, 192k, 256k.')
    return raw


def ffmpeg_audio_args(cache_format: str, bitrate: str) -> List[str]:
    if cache_format == 'mp3':
        return ['-c:a', 'libmp3lame', '-b:a', bitrate]
    if cache_format == 'ogg':
        return ['-c:a', 'libvorbis', '-b:a', bitrate]
    if cache_format == 'flac':
        return ['-c:a', 'flac']
    fail(f'Unsupported cache format "{cache_format}"')
    return []


def http_json(
    method: str,
    url: str,
    *,
    headers: Dict[str, str] | None = None,
    json_body: Dict[str, Any] | None = None,
    form_body: Dict[str, Any] | None = None,
    timeout: int = 20,
) -> Tuple[int, Dict[str, Any]]:
    data = None
    req_headers = dict(headers or {})
    if json_body is not None:
        data = json.dumps(json_body).encode('utf-8')
        req_headers['Content-Type'] = 'application/json'
    elif form_body is not None:
        data = urllib.parse.urlencode(form_body).encode('utf-8')
        req_headers['Content-Type'] = 'application/x-www-form-urlencoded'

    req = urllib.request.Request(url=url, data=data, method=method.upper(), headers=req_headers)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            body = resp.read().decode('utf-8', errors='ignore')
            status = int(resp.status)
    except urllib.error.HTTPError as exc:
        body = exc.read().decode('utf-8', errors='ignore')
        status = int(exc.code)
    except Exception as exc:
        return 599, {'error': str(exc)}

    try:
        payload = json.loads(body) if body else {}
    except Exception:
        payload = {'raw': body}
    return status, payload if isinstance(payload, dict) else {'raw': payload}


def extract_year(value: str) -> str:
    text = str(value or '').strip()
    match = re.match(r'^(\d{4})', text)
    if match:
        return match.group(1)
    return '0000'


def list_artist_names(raw_list: Any) -> List[str]:
    artists: List[str] = []
    for raw in raw_list or []:
        if not isinstance(raw, dict):
            continue
        name = str(raw.get('name', '')).strip()
        if name:
            artists.append(name)
    return artists


def _coerce_nonnegative_int(value: Any) -> int:
    try:
        parsed = int(value)
    except Exception:
        return 0
    return parsed if parsed > 0 else 0


def select_best_image_url(raw_images: Any) -> str:
    best_url = ''
    best_score = -1
    for raw in raw_images or []:
        if not isinstance(raw, dict):
            continue
        url = str(raw.get('url', '')).strip()
        if not url:
            continue
        width = _coerce_nonnegative_int(raw.get('width'))
        height = _coerce_nonnegative_int(raw.get('height'))
        score = width * height if width and height else max(width, height, 0)
        if score > best_score:
            best_url = url
            best_score = score
    return best_url


def detect_image_extension(url: str, content_type: str) -> str:
    ct = str(content_type or '').strip().lower()
    if 'image/png' in ct:
        return '.png'
    if 'image/webp' in ct:
        return '.webp'
    if 'image/jpeg' in ct or 'image/jpg' in ct:
        return '.jpg'

    path = urllib.parse.urlparse(str(url or '')).path.lower()
    if path.endswith('.png'):
        return '.png'
    if path.endswith('.webp'):
        return '.webp'
    if path.endswith('.jpeg') or path.endswith('.jpg'):
        return '.jpg'
    return '.jpg'


def _download_image_bytes(url: str, *, timeout: int = 20) -> Tuple[bytes, str]:
    req = urllib.request.Request(
        url=str(url).strip(),
        method='GET',
        headers={'User-Agent': 'musicbox-spotify-cache/1.0'},
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        content = resp.read()
        content_type = str(resp.headers.get('Content-Type', '')).strip()
    return content, content_type


def download_cover_art_file(target_folder: Path, image_url: str, *, basename: str = 'cover') -> str:
    url = str(image_url or '').strip()
    if not url:
        return ''

    transient_statuses = {429, 500, 502, 503, 504}
    delay_s = 1.0
    last_error = ''
    payload: bytes = b''
    content_type = ''

    for attempt in range(1, 4):
        try:
            payload, content_type = _download_image_bytes(url, timeout=20)
            if len(payload) < MIN_VALID_IMAGE_BYTES:
                last_error = f'image payload too small ({len(payload)} bytes)'
            elif content_type and not content_type.lower().startswith('image/'):
                last_error = f'non-image content type: {content_type}'
            else:
                ext = detect_image_extension(url, content_type)
                final_name = f'{basename}{ext}'
                final_path = target_folder / final_name
                tmp_path = target_folder / f'.{final_name}.tmp'
                target_folder.mkdir(parents=True, exist_ok=True)
                tmp_path.write_bytes(payload)
                tmp_path.replace(final_path)
                for other_ext in KNOWN_IMAGE_SUFFIXES:
                    candidate = target_folder / f'{basename}{other_ext}'
                    if candidate == final_path:
                        continue
                    try:
                        if candidate.exists():
                            candidate.unlink()
                    except Exception:
                        pass
                return final_name
        except urllib.error.HTTPError as exc:
            code = int(exc.code)
            last_error = f'http {code}'
            if code in transient_statuses and attempt < 3:
                time.sleep(delay_s)
                delay_s = min(8.0, delay_s * 1.8)
                continue
            return ''
        except Exception as exc:
            last_error = str(exc)
            if attempt < 3:
                time.sleep(delay_s)
                delay_s = min(8.0, delay_s * 1.8)
                continue
            return ''

    if last_error:
        print(f'cover download warning: {last_error}', file=sys.stderr)
    return ''


def find_existing_cover_file(target_folder: Path, *, basename: str = 'cover') -> str:
    for ext in ('.jpg', '.jpeg', '.png', '.webp'):
        candidate = target_folder / f'{basename}{ext}'
        if not candidate.exists() or not candidate.is_file():
            continue
        try:
            if candidate.stat().st_size >= MIN_VALID_IMAGE_BYTES:
                return candidate.name
        except Exception:
            continue
    return ''


def _move_cover_file_basename(target_folder: Path, *, src_basename: str, dst_basename: str) -> str:
    src_name = find_existing_cover_file(target_folder, basename=src_basename)
    if not src_name:
        return ''
    src_path = target_folder / src_name
    suffix = src_path.suffix.lower() or '.jpg'
    if suffix not in KNOWN_IMAGE_SUFFIXES:
        suffix = '.jpg'
    dst_path = target_folder / f'{dst_basename}{suffix}'
    try:
        if dst_path.exists() and dst_path != src_path:
            dst_path.unlink()
        src_path.replace(dst_path)
        for other_ext in KNOWN_IMAGE_SUFFIXES:
            candidate = target_folder / f'{dst_basename}{other_ext}'
            if candidate == dst_path:
                continue
            if candidate.exists():
                candidate.unlink()
        return dst_path.name
    except Exception:
        return ''


def ensure_cover_art(
    target_folder: Path,
    metadata: Dict[str, Any],
    *,
    basename: str = 'cover',
    legacy_basenames: Tuple[str, ...] | None = None,
) -> str:
    existing = find_existing_cover_file(target_folder, basename=basename)
    if existing:
        return existing
    for legacy in legacy_basenames or ():
        old_base = str(legacy or '').strip()
        if not old_base or old_base == basename:
            continue
        moved = _move_cover_file_basename(target_folder, src_basename=old_base, dst_basename=basename)
        if moved:
            return moved
    image_url = str(metadata.get('cover_url', '')).strip()
    if not image_url:
        return ''
    return download_cover_art_file(target_folder, image_url, basename=basename)


def is_valid_audio_file(path: Path) -> bool:
    if not path.exists() or not path.is_file():
        return False
    if path.suffix.lower() not in KNOWN_AUDIO_SUFFIXES:
        return False
    try:
        return path.stat().st_size >= MIN_VALID_BYTES
    except Exception:
        return False


def build_track_basename(track: Dict[str, Any], *, year: str = '') -> str:
    artists = [str(name).strip() for name in track.get('artists', []) if str(name).strip()]
    artist_text = ', '.join(artists[:2]) or 'Unknown Artist'
    title = str(track.get('name', '')).strip() or 'Untitled'
    year_text = extract_year(year)
    if year_text and year_text != '0000':
        return slug(f'{artist_text} - {year_text} - {title}', fallback='track')
    return slug(f'{artist_text} - {title}', fallback='track')


def build_track_filename(
    track: Dict[str, Any],
    index: int,
    total: int,
    extension: str,
    *,
    numbered: bool,
    year: str = '',
) -> str:
    base_name = build_track_basename(track, year=(year if not numbered else ''))
    if not numbered:
        return f'{base_name}{extension}'
    width = max(2, len(str(max(1, total))))
    return f'{index:0{width}d} - {base_name}{extension}'


def build_expected_filenames(
    tracks: List[Dict[str, Any]],
    extension: str,
    *,
    numbered: bool,
    year: str = '',
) -> List[str]:
    total = len(tracks)
    out: List[str] = []
    for index, track in enumerate(tracks, start=1):
        out.append(build_track_filename(track, index, total, extension, numbered=numbered, year=year))
    return out


def read_manifest(folder: Path) -> Dict[str, Any]:
    path = folder / MANIFEST_NAME
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except Exception:
        return {}
    return data if isinstance(data, dict) else {}


def write_manifest(folder: Path, payload: Dict[str, Any]) -> None:
    path = folder / MANIFEST_NAME
    path.write_text(json.dumps(payload, indent=2, sort_keys=True))


def copy_if_valid(src: Path, dst: Path) -> None:
    if not is_valid_audio_file(src):
        return
    dst.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(src, dst)


def cleanup_dir(path: Path) -> None:
    try:
        if path.exists():
            shutil.rmtree(path)
    except Exception:
        pass


def to_relative(path: Path, media_dir: Path) -> str:
    abs_path = path.resolve()
    media_root = media_dir.resolve()
    try:
        return str(abs_path.relative_to(media_root))
    except Exception:
        return str(abs_path)


class SpotifySession:
    def __init__(self, oauth_path: Path) -> None:
        self.oauth_path = oauth_path
        provided_access_token = str(os.environ.get('MUSICBOX_SPOTIFY_ACCESS_TOKEN', '')).strip()
        provided_expires_at_raw = str(os.environ.get('MUSICBOX_SPOTIFY_ACCESS_EXPIRES_AT', '')).strip()
        provided_client_id = str(os.environ.get('MUSICBOX_SPOTIFY_CLIENT_ID', '')).strip()
        refresh_flag = str(os.environ.get('MUSICBOX_SPOTIFY_ENABLE_REFRESH', '1')).strip().lower()
        self.refresh_enabled = refresh_flag not in {'0', 'false', 'no', 'off'}

        self.payload = self._load_payload(allow_missing=bool(provided_access_token))
        ttl_raw = os.environ.get('MUSICBOX_SPOTIFY_MIN_ACCESS_TTL_SECONDS', str(DEFAULT_MIN_ACCESS_TTL_SECONDS))
        try:
            ttl_value = int(str(ttl_raw or DEFAULT_MIN_ACCESS_TTL_SECONDS))
        except Exception:
            ttl_value = DEFAULT_MIN_ACCESS_TTL_SECONDS
        self.min_access_ttl_seconds = max(30, ttl_value)

        self.client_id = provided_client_id or str(self.payload.get('client_id', '')).strip()
        self.refresh_token = str(self.payload.get('refresh_token', '')).strip()
        self.access_token = provided_access_token or str(self.payload.get('access_token', '')).strip()
        try:
            provided_expires_at = int(provided_expires_at_raw) if provided_expires_at_raw else 0
        except Exception:
            provided_expires_at = 0
        self.expires_at = provided_expires_at or int(self.payload.get('expires_at', 0) or 0)

        if not self.access_token:
            fail('Spotify access token missing for capture worker')
        if self.refresh_enabled and not self.client_id:
            fail(f'Spotify client_id missing in {self.oauth_path}')
        if self.refresh_enabled and not self.refresh_token:
            fail(f'Spotify refresh_token missing in {self.oauth_path}')
        self.ensure_access_token()

    def _load_payload(self, *, allow_missing: bool = False) -> Dict[str, Any]:
        if not self.oauth_path.exists():
            if allow_missing:
                return {}
            fail(f'Spotify OAuth file not found: {self.oauth_path}')
        try:
            return json.loads(self.oauth_path.read_text())
        except Exception as exc:
            if allow_missing:
                return {}
            fail(f'Failed to read Spotify OAuth file: {exc}')

    def _save_payload(self) -> None:
        self.payload['access_token'] = self.access_token
        self.payload['expires_at'] = self.expires_at
        if self.refresh_token:
            self.payload['refresh_token'] = self.refresh_token
        self.payload['updated_at'] = int(time.time())
        self.oauth_path.parent.mkdir(parents=True, exist_ok=True)
        self.oauth_path.write_text(json.dumps(self.payload, indent=2, sort_keys=True))

    def refresh(self) -> None:
        if not self.refresh_enabled:
            fail('Spotify access token expired during import. Retry once from the UI.')
        status, data = http_json(
            'POST',
            TOKEN_URL,
            form_body={
                'grant_type': 'refresh_token',
                'refresh_token': self.refresh_token,
                'client_id': self.client_id,
            },
        )
        if status >= 300:
            fail(data.get('error_description') or data.get('error') or f'Spotify token refresh failed ({status})')

        token = str(data.get('access_token', '')).strip()
        if not token:
            fail('Spotify refresh response missing access_token')
        expires_in = int(data.get('expires_in', 3600))
        self.access_token = token
        self.expires_at = int(time.time()) + max(60, expires_in - 15)
        maybe_refresh = str(data.get('refresh_token', '')).strip()
        if maybe_refresh:
            self.refresh_token = maybe_refresh
        self._save_payload()

    def ensure_access_token(self) -> str:
        now = int(time.time())
        if self.access_token and self.expires_at > now + self.min_access_ttl_seconds:
            return self.access_token

        # In read-only token mode we intentionally do not refresh from this
        # worker process to avoid OAuth token write races.
        if not self.refresh_enabled:
            if self.access_token and self.expires_at > now + 5:
                return self.access_token
            fail('Spotify access token expired during import. Retry once from the UI.')
            return self.access_token
        self.refresh()
        return self.access_token

    def request(
        self,
        method: str,
        path_or_url: str,
        *,
        params: Dict[str, Any] | None = None,
        json_body: Dict[str, Any] | None = None,
    ) -> Dict[str, Any]:
        url = path_or_url if path_or_url.startswith('http') else f'{API_BASE}{path_or_url}'
        if params:
            query = urllib.parse.urlencode({k: v for k, v in params.items() if v is not None}, doseq=True)
            url = f'{url}?{query}'

        transient_statuses = {429, 500, 502, 503, 504, 599}
        max_attempts = 5
        delay_s = 1.0
        last_error = ''

        for attempt in range(1, max_attempts + 1):
            token = self.ensure_access_token()
            headers = {'Authorization': f'Bearer {token}'}
            status, data = http_json(method, url, headers=headers, json_body=json_body)
            if status == 401:
                if self.refresh_enabled:
                    self.refresh()
                    headers['Authorization'] = f'Bearer {self.access_token}'
                    status, data = http_json(method, url, headers=headers, json_body=json_body)
                else:
                    fail('Spotify access token expired during import. Retry once from the UI.')

            if status < 300:
                return data

            err = data.get('error')
            if isinstance(err, dict):
                err_msg = str(err.get('message', '')).strip()
            else:
                err_msg = str(err).strip() if err is not None else ''
            message = str(data.get('error_description', '')).strip() or err_msg
            last_error = message or f'Spotify API call failed ({status} {method} {url})'

            if status in transient_statuses and attempt < max_attempts:
                time.sleep(delay_s)
                delay_s = min(8.0, delay_s * 1.8)
                continue

            fail(last_error)

        fail(last_error or f'Spotify API call failed ({method} {url})')
        return {}


def parse_track(item: Dict[str, Any]) -> Dict[str, Any] | None:
    if not isinstance(item, dict):
        return None
    track_id = str(item.get('id', '')).strip()
    track_uri = str(item.get('uri', '')).strip()
    name = str(item.get('name', '')).strip()
    duration_ms = int(item.get('duration_ms', 0) or 0)
    if not track_id or not track_uri or not name or duration_ms <= 0:
        return None

    artists = list_artist_names(item.get('artists'))
    return {
        'id': track_id,
        'uri': track_uri,
        'name': name,
        'artists': artists,
        'duration_ms': duration_ms,
    }


def extract_playlist_item_track(raw_item: Any) -> Dict[str, Any]:
    if not isinstance(raw_item, dict):
        return {}
    # Migration-compatible payloads:
    # - legacy playlist endpoint wraps with {"track": {...}}
    # - new endpoint wraps with {"item": {...}}
    if isinstance(raw_item.get('item'), dict):
        return raw_item.get('item') or {}
    if isinstance(raw_item.get('track'), dict):
        return raw_item.get('track') or {}
    return raw_item


def resolve_tracks(session: SpotifySession, spotify_uri: str) -> Tuple[str, Dict[str, Any], List[Dict[str, Any]]]:
    media_type, media_id = spotify_uri.split(':', 2)[1:]
    tracks: List[Dict[str, Any]] = []

    if media_type == 'track':
        track_payload = session.request('GET', f'/tracks/{media_id}')
        track = parse_track(track_payload)
        if not track:
            fail(f'Could not resolve track metadata for {spotify_uri}')
        tracks.append(track)
        metadata = {
            'title': track['name'],
            'primary_artist': (track['artists'][0] if track['artists'] else 'Unknown Artist'),
            'year': extract_year(str(((track_payload.get('album') or {}) or {}).get('release_date', ''))),
            'cover_url': select_best_image_url(((track_payload.get('album') or {}) or {}).get('images')),
        }
        return media_type, metadata, tracks

    if media_type == 'album':
        album = session.request('GET', f'/albums/{media_id}')
        title = str(album.get('name', '')).strip() or media_id
        album_artists = list_artist_names(album.get('artists'))
        album_artist = album_artists[0] if album_artists else 'Unknown Artist'
        year = extract_year(str(album.get('release_date', '')))

        next_url = f'{API_BASE}/albums/{media_id}/tracks?limit=50'
        while next_url:
            page = session.request('GET', next_url)
            for item in page.get('items', []) or []:
                track = parse_track(item)
                if track:
                    tracks.append(track)
            next_url = str(page.get('next', '') or '')

        metadata = {
            'title': title,
            'album_artist': album_artist,
            'year': year,
            'cover_url': select_best_image_url(album.get('images')),
        }
        return media_type, metadata, tracks

    if media_type == 'playlist':
        playlist = session.request('GET', f'/playlists/{media_id}', params={'fields': 'name,snapshot_id,images'})
        title = str(playlist.get('name', '')).strip() or media_id
        snapshot_id = str(playlist.get('snapshot_id', '')).strip()

        # Use the migration-compatible endpoint and payload format.
        next_url = f'{API_BASE}/playlists/{media_id}/items?limit=50'
        while next_url:
            page = session.request('GET', next_url)
            for wrapped in page.get('items', []) or []:
                track = parse_track(extract_playlist_item_track(wrapped))
                if track:
                    tracks.append(track)
            next_url = str(page.get('next', '') or '')

        metadata = {
            'title': title,
            'snapshot_id': snapshot_id,
            'cover_url': select_best_image_url(playlist.get('images')),
        }
        return media_type, metadata, tracks

    fail(f'Unsupported spotify type: {media_type}')
    return media_type, {}, tracks


def ensure_fifo(path: Path) -> None:
    if path.exists():
        if path.is_fifo():
            return
        path.unlink()
    path.parent.mkdir(parents=True, exist_ok=True)
    os.mkfifo(path, mode=0o666)


def find_librespot_binary() -> str:
    env_value = str(os.environ.get('MUSICBOX_LIBRESPOT_BIN', '')).strip()
    if env_value:
        candidate = Path(env_value).expanduser()
        if candidate.exists():
            return str(candidate)

    found = shutil.which('librespot')
    if found:
        return found

    home_candidate = Path.home() / '.cargo' / 'bin' / 'librespot'
    if home_candidate.exists():
        return str(home_candidate)

    fail('librespot binary not found. Install with `cargo install --locked librespot --version 0.8.0`.')
    return 'librespot'


def read_log_tail(path: Path, max_lines: int = 24) -> str:
    if not path.exists():
        return ''
    try:
        lines = path.read_text(errors='replace').splitlines()
    except Exception:
        return ''
    return '\n'.join(lines[-max_lines:])


def list_devices(session: SpotifySession) -> List[Dict[str, Any]]:
    payload = session.request('GET', '/me/player/devices')
    devices = payload.get('devices') if isinstance(payload, dict) else []
    return [item for item in (devices or []) if isinstance(item, dict)]


def choose_device_id(
    devices: List[Dict[str, Any]],
    *,
    preferred_name: str,
    baseline_ids: set[str],
) -> str:
    preferred = str(preferred_name or '').strip().casefold()

    if preferred:
        for device in devices:
            name = str(device.get('name', '')).strip().casefold()
            if name != preferred:
                continue
            device_id = str(device.get('id', '')).strip()
            if device_id:
                return device_id

    for device in devices:
        device_id = str(device.get('id', '')).strip()
        if device_id and device_id not in baseline_ids:
            return device_id

    if preferred:
        for device in devices:
            name = str(device.get('name', '')).strip().casefold()
            if preferred not in name and name not in preferred:
                continue
            device_id = str(device.get('id', '')).strip()
            if device_id:
                return device_id

    return ''


def wait_for_device_id(
    session: SpotifySession,
    device_name: str,
    *,
    timeout_s: int = 90,
    baseline_ids: set[str] | None = None,
    librespot: subprocess.Popen[str] | None = None,
    log_path: Path | None = None,
) -> str:
    baseline = set(baseline_ids or set())
    deadline = time.time() + max(10, int(timeout_s))

    while time.time() < deadline:
        if librespot is not None and librespot.poll() is not None:
            tail = read_log_tail(log_path or Path('/tmp/librespot-capture.log'))
            hint = f'\nlibrespot log tail:\n{tail}' if tail else ''
            fail(f'librespot exited before capture device was ready (rc={librespot.returncode}){hint}')

        devices = list_devices(session)
        chosen = choose_device_id(devices, preferred_name=device_name, baseline_ids=baseline)
        if chosen:
            return chosen
        time.sleep(1.0)

    latest_names = [str(item.get('name', '')).strip() for item in list_devices(session)]
    fail(
        f'Spotify device "{device_name}" did not appear in {int(timeout_s)}s. '
        f'Visible devices: {latest_names}'
    )
    return ''


def start_librespot(
    access_token: str,
    device_name: str,
    fifo_path: Path,
    work_dir: Path,
    librespot_bin: str,
) -> subprocess.Popen[str]:
    log_path = work_dir / 'librespot-capture.log'
    log_path.parent.mkdir(parents=True, exist_ok=True)
    log_handle = open(log_path, 'a', encoding='utf-8')
    cmd = [
        librespot_bin,
        '--name',
        device_name,
        '--backend',
        'pipe',
        '--device',
        str(fifo_path),
        '--format',
        'S16',
        '--bitrate',
        '320',
        '--initial-volume',
        '100',
        '--volume-ctrl',
        'fixed',
        '--disable-audio-cache',
        '--access-token',
        access_token,
    ]
    return subprocess.Popen(cmd, stdout=log_handle, stderr=log_handle, start_new_session=True, text=True)


def start_capture(
    fifo_path: Path,
    out_path: Path,
    capture_bytes: int,
    audio_codec_args: List[str],
) -> subprocess.Popen[str]:
    out_path.parent.mkdir(parents=True, exist_ok=True)
    byte_count = max(PCM_BYTES_PER_SECOND // 10, int(capture_bytes))
    codec = ' '.join(shlex.quote(part) for part in audio_codec_args)
    cmd = (
        f'head -c {byte_count} < {shlex.quote(str(fifo_path))} | '
        'ffmpeg -hide_banner -loglevel error -nostdin -y '
        '-f s16le '
        f'-ar {PCM_SAMPLE_RATE} '
        f'-ac {PCM_CHANNELS} '
        '-i pipe:0 '
        f'{codec} '
        f'{shlex.quote(str(out_path))}'
    )
    return subprocess.Popen(
        ['bash', '-lc', cmd],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.PIPE,
        text=True,
        start_new_session=True,
    )


def capture_tracks(
    session: SpotifySession,
    tracks: List[Dict[str, Any]],
    out_dir: Path,
    device_name: str,
    librespot_bin: str,
    cache_format: str,
    cache_bitrate: str,
    *,
    numbered: bool,
    rel_result_for_single: bool,
) -> Path:
    # Use a per-process FIFO so stale readers from earlier failed jobs cannot
    # consume bytes from current captures.
    fifo_path = Path(f'/tmp/musicbox-librespot-capture-{os.getpid()}.pcm')
    ensure_fifo(fifo_path)
    log_path = Path('/tmp/librespot-capture.log')
    runtime_device = capture_device_name(device_name)

    try:
        baseline_ids = {
            str(item.get('id', '')).strip()
            for item in list_devices(session)
            if str(item.get('id', '')).strip()
        }
    except Exception:
        baseline_ids = set()

    librespot = start_librespot(
        session.ensure_access_token(),
        runtime_device,
        fifo_path,
        Path('/tmp'),
        librespot_bin,
    )
    try:
        device_id = wait_for_device_id(
            session,
            device_name=runtime_device,
            timeout_s=90,
            baseline_ids=baseline_ids,
            librespot=librespot,
            log_path=log_path,
        )
        session.request('PUT', '/me/player', json_body={'device_ids': [device_id], 'play': False})
        time.sleep(0.5)
        extension = CACHE_EXTENSION.get(cache_format, '.mp3')
        codec_args = ffmpeg_audio_args(cache_format, cache_bitrate)
        total = len(tracks)

        for index, track in enumerate(tracks, start=1):
            filename = build_track_filename(track, index, total, extension, numbered=numbered)
            out_path = out_dir / filename

            if is_valid_audio_file(out_path):
                continue

            max_attempts = 2
            success = False
            last_error = ''
            for attempt in range(1, max_attempts + 1):
                capture_s = max(1.5, (float(track['duration_ms']) / 1000.0) + 0.8)
                capture_bytes = int(capture_s * PCM_BYTES_PER_SECOND)
                ffmpeg = start_capture(fifo_path, out_path, capture_bytes, codec_args)
                time.sleep(0.3)
                session.request('PUT', '/me/player/play', params={'device_id': device_id}, json_body={'uris': [track['uri']]})

                timeout_s = capture_s + 60.0
                ffmpeg_stderr = ''
                timed_out = False
                try:
                    _, ffmpeg_stderr = ffmpeg.communicate(timeout=timeout_s)
                except subprocess.TimeoutExpired:
                    timed_out = True
                    try:
                        os.killpg(ffmpeg.pid, signal.SIGTERM)
                    except Exception:
                        ffmpeg.kill()
                    try:
                        _, ffmpeg_stderr = ffmpeg.communicate(timeout=5)
                    except subprocess.TimeoutExpired:
                        try:
                            os.killpg(ffmpeg.pid, signal.SIGKILL)
                        except Exception:
                            ffmpeg.kill()
                        _, ffmpeg_stderr = ffmpeg.communicate(timeout=5)
                finally:
                    try:
                        session.request('PUT', '/me/player/pause', params={'device_id': device_id})
                    except Exception:
                        pass

                if timed_out:
                    last_error = f'Capture timeout for {track["uri"]} (attempt {attempt}/{max_attempts}): {ffmpeg_stderr or "ffmpeg timeout"}'
                elif ffmpeg.returncode != 0:
                    last_error = f'ffmpeg failed for {track["uri"]} (attempt {attempt}/{max_attempts}): {ffmpeg_stderr or "unknown ffmpeg error"}'
                elif not is_valid_audio_file(out_path):
                    last_error = f'Capture produced invalid file for {track["uri"]} (attempt {attempt}/{max_attempts}): {out_path}'
                else:
                    success = True
                    break

                try:
                    if out_path.exists():
                        out_path.unlink()
                except Exception:
                    pass
                time.sleep(1.0)

            if not success:
                fail(last_error or f'Capture failed for {track["uri"]}')
            time.sleep(0.3)
    finally:
        if librespot.poll() is None:
            librespot.send_signal(signal.SIGTERM)
            try:
                librespot.wait(timeout=5)
            except Exception:
                librespot.kill()
        try:
            if fifo_path.exists() and fifo_path.is_fifo():
                fifo_path.unlink()
        except Exception:
            pass

    if len(tracks) == 1 and rel_result_for_single:
        extension = CACHE_EXTENSION.get(cache_format, '.mp3')
        filename = build_track_filename(tracks[0], 1, 1, extension, numbered=numbered)
        only = out_dir / filename
        if only.exists():
            return only
    return out_dir


def finalize_single_import(
    *,
    import_root: Path,
    media_dir: Path,
    track: Dict[str, Any],
    metadata: Dict[str, Any],
    session: SpotifySession,
    device_name: str,
    librespot_bin: str,
    cache_format: str,
    cache_bitrate: str,
) -> str:
    extension = CACHE_EXTENSION.get(cache_format, '.mp3')
    singles_dir = import_root / 'Singles'
    single_year = str(metadata.get('year', '')).strip()
    final_path = singles_dir / build_track_filename(track, 1, 1, extension, numbered=False, year=single_year)
    legacy_path = singles_dir / build_track_filename(track, 1, 1, extension, numbered=False, year='')
    legacy_basenames: Tuple[str, ...] = ()
    if legacy_path != final_path:
        legacy_basenames = (legacy_path.stem,)

    if not is_valid_audio_file(final_path) and legacy_path != final_path and is_valid_audio_file(legacy_path):
        singles_dir.mkdir(parents=True, exist_ok=True)
        if final_path.exists():
            final_path.unlink()
        legacy_path.rename(final_path)

    if is_valid_audio_file(final_path):
        ensure_cover_art(
            final_path.parent,
            metadata,
            basename=final_path.stem,
            legacy_basenames=legacy_basenames,
        )
        return to_relative(final_path, media_dir)

    temp_root = import_root / IMPORTING_DIR_NAME / f'spotify-{int(time.time())}-{os.getpid()}-track'
    work_dir = temp_root / 'Singles'
    work_dir.mkdir(parents=True, exist_ok=True)

    try:
        result_path = capture_tracks(
            session=session,
            tracks=[track],
            out_dir=work_dir,
            device_name=device_name,
            librespot_bin=librespot_bin,
            cache_format=cache_format,
            cache_bitrate=cache_bitrate,
            numbered=False,
            rel_result_for_single=True,
        )
        if not is_valid_audio_file(result_path):
            fail(f'Import produced invalid track file: {result_path}')

        singles_dir.mkdir(parents=True, exist_ok=True)
        if final_path.exists():
            final_path.unlink()
        result_path.rename(final_path)
        ensure_cover_art(
            final_path.parent,
            metadata,
            basename=final_path.stem,
            legacy_basenames=legacy_basenames,
        )
        return to_relative(final_path, media_dir)
    finally:
        cleanup_dir(temp_root)


def seed_album_resume(final_dir: Path, work_dir: Path, expected_files: List[str]) -> None:
    for filename in expected_files:
        src = final_dir / filename
        dst = work_dir / filename
        copy_if_valid(src, dst)


def seed_playlist_resume(
    final_dir: Path,
    work_dir: Path,
    tracks: List[Dict[str, Any]],
    expected_files: List[str],
    manifest: Dict[str, Any],
) -> None:
    uri_to_file: Dict[str, str] = {}
    for entry in manifest.get('tracks', []) if isinstance(manifest.get('tracks'), list) else []:
        if not isinstance(entry, dict):
            continue
        uri = str(entry.get('uri', '')).strip()
        filename = str(entry.get('file', '')).strip()
        if uri and filename and uri not in uri_to_file:
            uri_to_file[uri] = filename

    for index, track in enumerate(tracks):
        expected = expected_files[index]
        src_name = uri_to_file.get(str(track.get('uri', '')).strip())
        if src_name:
            copy_if_valid(final_dir / src_name, work_dir / expected)
            continue
        copy_if_valid(final_dir / expected, work_dir / expected)


def all_expected_files_present(folder: Path, expected_files: List[str]) -> bool:
    if not folder.exists() or not folder.is_dir():
        return False
    for filename in expected_files:
        if not is_valid_audio_file(folder / filename):
            return False
    return True


def finalize_collection_import(
    *,
    spotify_uri: str,
    media_type: str,
    metadata: Dict[str, Any],
    tracks: List[Dict[str, Any]],
    import_root: Path,
    media_dir: Path,
    session: SpotifySession,
    device_name: str,
    librespot_bin: str,
    cache_format: str,
    cache_bitrate: str,
) -> str:
    extension = CACHE_EXTENSION.get(cache_format, '.mp3')

    if media_type == 'album':
        album_artist = str(metadata.get('album_artist', '')).strip() or 'Unknown Artist'
        year = str(metadata.get('year', '')).strip() or '0000'
        title = str(metadata.get('title', '')).strip() or 'Album'
        folder_name = slug(f'{album_artist} - {year} - {title}', fallback='Album')
    elif media_type == 'playlist':
        title = str(metadata.get('title', '')).strip() or 'Playlist'
        folder_name = slug(f'Playlist - {title}', fallback='Playlist')
    else:
        fail(f'Unsupported collection media type: {media_type}')
        return ''

    final_dir = import_root / folder_name
    expected_files = build_expected_filenames(tracks, extension, numbered=True)
    existing_manifest = read_manifest(final_dir)

    if all_expected_files_present(final_dir, expected_files):
        ensure_cover_art(final_dir, metadata, basename=folder_name, legacy_basenames=('cover',))
        if media_type == 'playlist':
            cached_snapshot = str(existing_manifest.get('snapshot_id', '')).strip()
            latest_snapshot = str(metadata.get('snapshot_id', '')).strip()
            if cached_snapshot and latest_snapshot and cached_snapshot == latest_snapshot:
                return to_relative(final_dir, media_dir)
        else:
            return to_relative(final_dir, media_dir)

    temp_root = import_root / IMPORTING_DIR_NAME / f'spotify-{int(time.time())}-{os.getpid()}-{media_type}'
    work_dir = temp_root / folder_name
    work_dir.mkdir(parents=True, exist_ok=True)

    try:
        if media_type == 'album' and final_dir.exists():
            seed_album_resume(final_dir, work_dir, expected_files)
        if media_type == 'playlist' and final_dir.exists():
            seed_playlist_resume(final_dir, work_dir, tracks, expected_files, existing_manifest)

        capture_tracks(
            session=session,
            tracks=tracks,
            out_dir=work_dir,
            device_name=device_name,
            librespot_bin=librespot_bin,
            cache_format=cache_format,
            cache_bitrate=cache_bitrate,
            numbered=True,
            rel_result_for_single=False,
        )

        if not all_expected_files_present(work_dir, expected_files):
            fail(f'Import incomplete for {spotify_uri}')

        cover_file = ensure_cover_art(work_dir, metadata, basename=folder_name, legacy_basenames=('cover',))

        manifest_tracks = []
        for index, track in enumerate(tracks, start=1):
            manifest_tracks.append({
                'index': index,
                'uri': str(track.get('uri', '')).strip(),
                'name': str(track.get('name', '')).strip(),
                'file': expected_files[index - 1],
            })

        manifest_payload: Dict[str, Any] = {
            'source_uri': spotify_uri,
            'type': media_type,
            'title': str(metadata.get('title', '')).strip(),
            'track_count': len(tracks),
            'cache_format': cache_format,
            'updated_at': int(time.time()),
            'tracks': manifest_tracks,
        }
        if media_type == 'album':
            manifest_payload['album_artist'] = str(metadata.get('album_artist', '')).strip()
            manifest_payload['year'] = str(metadata.get('year', '')).strip()
        if media_type == 'playlist':
            manifest_payload['snapshot_id'] = str(metadata.get('snapshot_id', '')).strip()
        if cover_file:
            manifest_payload['cover_file'] = cover_file

        write_manifest(work_dir, manifest_payload)

        if final_dir.exists():
            shutil.rmtree(final_dir)
        final_dir.parent.mkdir(parents=True, exist_ok=True)
        work_dir.rename(final_dir)
        return to_relative(final_dir, media_dir)
    finally:
        cleanup_dir(temp_root)


def main() -> None:
    if len(sys.argv) < 4:
        fail('usage: spotify-cache-fetch <spotify-uri> <import-root> <media-dir>', code=2)

    spotify_uri = normalize_spotify_uri(sys.argv[1])
    import_root = Path(sys.argv[2]).resolve()
    media_dir = Path(sys.argv[3]).resolve()

    oauth_path = Path(
        os.environ.get('MUSICBOX_SPOTIFY_OAUTH_PATH', '/home/musicbox/musicbox/config/spotify_oauth.json')
    ).resolve()
    device_name = str(os.environ.get('MUSICBOX_SPOTIFY_DEVICE_NAME', '')).strip() or 'musicbox-capture'
    cache_format = normalize_cache_format(os.environ.get('MUSICBOX_SPOTIFY_CACHE_FORMAT', DEFAULT_CACHE_FORMAT))
    default_bitrate = '160k' if cache_format == 'ogg' else DEFAULT_CACHE_BITRATE
    cache_bitrate = normalize_bitrate(os.environ.get('MUSICBOX_SPOTIFY_CACHE_BITRATE', default_bitrate), fallback=default_bitrate)
    librespot_bin = find_librespot_binary()

    import_root.mkdir(parents=True, exist_ok=True)
    session = SpotifySession(oauth_path)

    media_type, metadata, tracks = resolve_tracks(session, spotify_uri)
    if not tracks:
        fail(f'No tracks resolved for {spotify_uri}')

    if media_type == 'track':
        relpath = finalize_single_import(
            import_root=import_root,
            media_dir=media_dir,
            track=tracks[0],
            metadata=metadata,
            session=session,
            device_name=device_name,
            librespot_bin=librespot_bin,
            cache_format=cache_format,
            cache_bitrate=cache_bitrate,
        )
        print(relpath)
        return

    relpath = finalize_collection_import(
        spotify_uri=spotify_uri,
        media_type=media_type,
        metadata=metadata,
        tracks=tracks,
        import_root=import_root,
        media_dir=media_dir,
        session=session,
        device_name=device_name,
        librespot_bin=librespot_bin,
        cache_format=cache_format,
        cache_bitrate=cache_bitrate,
    )
    print(relpath)


if __name__ == '__main__':
    main()
