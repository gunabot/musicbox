#!/usr/bin/env python3
import argparse
import datetime as dt
import json
import os
import re
import subprocess
import sys
import tarfile
import tempfile
from pathlib import Path
from typing import Any, Dict, List

SERVICE_NAME = 'musicbox-status.service'
OVERLAYROOT_CONF = Path('/etc/overlayroot.conf')
OVERLAYROOT_LOCAL_CONF = Path('/etc/overlayroot.local.conf')
MODE_TO_VALUE = {
    'appliance': 'tmpfs:recurse=0,swap=1',
    'maintenance': 'disabled',
}


def run(cmd: List[str], check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, text=True, capture_output=True, check=check)


def run_stdout(cmd: List[str], default: str = '') -> str:
    try:
        return run(cmd).stdout.strip()
    except Exception:
        return default


def read_overlay_config_value(path: Path) -> str | None:
    if not path.exists():
        return None
    pattern = re.compile(r'^\s*overlayroot\s*=\s*(.+?)\s*$')
    for line in path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith('#'):
            continue
        match = pattern.match(line)
        if not match:
            continue
        value = match.group(1).strip()
        if len(value) >= 2 and ((value[0] == '"' and value[-1] == '"') or (value[0] == "'" and value[-1] == "'")):
            value = value[1:-1]
        return value
    return None


def overlay_config() -> Dict[str, Any]:
    local_value = read_overlay_config_value(OVERLAYROOT_LOCAL_CONF)
    if local_value is not None:
        source = str(OVERLAYROOT_LOCAL_CONF)
        value = local_value
    else:
        source = str(OVERLAYROOT_CONF)
        value = read_overlay_config_value(OVERLAYROOT_CONF) or ''

    mode = 'maintenance' if value in {'', 'disabled'} else 'appliance'
    return {'mode': mode, 'value': value, 'source': source}


def runtime_root_state() -> Dict[str, Any]:
    fstype = run_stdout(['findmnt', '-n', '-o', 'FSTYPE', '/'])
    source = run_stdout(['findmnt', '-n', '-o', 'SOURCE', '/'])
    return {
        'root_fstype': fstype,
        'root_source': source,
        'overlay_active': fstype == 'overlay',
    }


def mount_info(target: str) -> Dict[str, Any]:
    out = run_stdout(['findmnt', '-n', '-o', 'TARGET,SOURCE,FSTYPE,OPTIONS', target])
    if not out:
        return {'mounted': False, 'target': target}
    parts = out.split(maxsplit=3)
    while len(parts) < 4:
        parts.append('')
    return {
        'mounted': True,
        'target': parts[0],
        'source': parts[1],
        'fstype': parts[2],
        'options': parts[3],
    }


def is_writable(path: Path) -> bool:
    try:
        path.mkdir(parents=True, exist_ok=True)
        with tempfile.NamedTemporaryFile(dir=path, prefix='.musicbox-write-', delete=True):
            pass
        return True
    except Exception:
        return False


def service_state() -> Dict[str, str]:
    active = run_stdout(['systemctl', 'is-active', SERVICE_NAME], default='unknown')
    enabled = run_stdout(['systemctl', 'is-enabled', SERVICE_NAME], default='unknown')
    return {'active': active, 'enabled': enabled}


def overlayroot_installed() -> bool:
    if Path('/usr/share/initramfs-tools/scripts/init-bottom/overlayroot').exists():
        return True
    return bool(run_stdout(['dpkg-query', '-W', '-f=${Status}', 'overlayroot']).startswith('install ok installed'))


def status_payload() -> Dict[str, Any]:
    return {
        'timestamp': dt.datetime.now().isoformat(timespec='seconds'),
        'overlay_config': overlay_config(),
        'runtime_root': runtime_root_state(),
        'service': service_state(),
        'mounts': {
            '/data': mount_info('/data'),
            '/mnt/rwroot': mount_info('/mnt/rwroot'),
        },
    }


def print_payload(payload: Dict[str, Any], as_json: bool) -> None:
    if as_json:
        print(json.dumps(payload, indent=2, sort_keys=True))
        return

    print(f"time: {payload['timestamp']}")
    print(
        'mode: '
        f"{payload['overlay_config']['mode']} "
        f"(value={payload['overlay_config']['value']!r}, source={payload['overlay_config']['source']})"
    )
    print(
        'root: '
        f"fstype={payload['runtime_root']['root_fstype']} "
        f"source={payload['runtime_root']['root_source']} "
        f"overlay_active={payload['runtime_root']['overlay_active']}"
    )
    print(f"service: active={payload['service']['active']} enabled={payload['service']['enabled']}")
    for mountpoint, info in payload['mounts'].items():
        if not info.get('mounted'):
            print(f"{mountpoint}: not mounted")
            continue
        print(f"{mountpoint}: {info['source']} ({info['fstype']}) opts={info['options']}")


def doctor_payload() -> Dict[str, Any]:
    checks: List[Dict[str, Any]] = []

    cfg = overlay_config()
    runtime = runtime_root_state()
    svc = service_state()
    data_mount = mount_info('/data')
    rwroot_mount = mount_info('/mnt/rwroot')

    def add_check(name: str, ok: bool, details: str) -> None:
        checks.append({'name': name, 'ok': ok, 'details': details})

    add_check('overlayroot package', overlayroot_installed(), 'overlayroot components available')
    add_check('service active', svc['active'] == 'active', f"musicbox-status active={svc['active']}")
    add_check('data mounted', data_mount.get('mounted', False), f"/data mounted={data_mount.get('mounted', False)}")
    add_check('rwroot mounted', rwroot_mount.get('mounted', False), f"/mnt/rwroot mounted={rwroot_mount.get('mounted', False)}")

    if cfg['mode'] == 'appliance':
        add_check('data mount writable opts', 'rw' in str(data_mount.get('options', '')), f"/data opts={data_mount.get('options', '')}")
        add_check('rwroot writable opts', 'rw' in str(rwroot_mount.get('options', '')), f"/mnt/rwroot opts={rwroot_mount.get('options', '')}")

    writable_targets = [
        Path('/data/media'),
        Path('/data/config'),
        Path('/data/logs'),
        Path('/data/backups'),
    ]
    for path in writable_targets:
        add_check(f'{path} exists', path.exists(), f'{path} exists={path.exists()}')
        add_check(f'{path} writable', is_writable(path), f'{path} write test')

    if cfg['mode'] == 'appliance':
        add_check('appliance root runtime', runtime['overlay_active'], 'root must be overlay in appliance mode')
    else:
        add_check('maintenance root runtime', not runtime['overlay_active'], 'root should be non-overlay in maintenance mode')

    ok = all(item['ok'] for item in checks)
    return {
        'ok': ok,
        'overlay_config': cfg,
        'runtime_root': runtime,
        'service': svc,
        'checks': checks,
    }


def write_overlay_local(path: Path, value: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    content = (
        '# managed by musicbox CLI\n'
        'overlayroot_cfgdisk="disabled"\n'
        f'overlayroot="{value}"\n'
    )
    path.write_text(content)


def mode_target_paths() -> List[Path]:
    runtime = runtime_root_state()
    targets: List[Path] = [OVERLAYROOT_LOCAL_CONF]

    if runtime['overlay_active']:
        # In appliance mode, /etc is overlayed tmpfs. Persist mode changes on lower root too.
        run(['mount', '-o', 'remount,rw', '/mnt/rwroot'], check=False)
        lower = Path('/mnt/rwroot/etc/overlayroot.local.conf')
        if lower.parent.exists():
            targets.append(lower)

    unique: List[Path] = []
    seen = set()
    for item in targets:
        if str(item) in seen:
            continue
        seen.add(str(item))
        unique.append(item)
    return unique


def ensure_root() -> None:
    if os.geteuid() != 0:
        print('error: this command requires root (run with sudo)', file=sys.stderr)
        sys.exit(2)


def cmd_status(args: argparse.Namespace) -> None:
    print_payload(status_payload(), as_json=args.json)


def cmd_doctor(args: argparse.Namespace) -> None:
    payload = doctor_payload()
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print('doctor:', 'ok' if payload['ok'] else 'issues detected')
        for check in payload['checks']:
            state = 'OK' if check['ok'] else 'FAIL'
            print(f"- [{state}] {check['name']}: {check['details']}")
    if not payload['ok']:
        sys.exit(1)


def cmd_mode_get(args: argparse.Namespace) -> None:
    payload = overlay_config()
    payload.update(runtime_root_state())
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"configured mode: {payload['mode']} ({payload['value']!r} from {payload['source']})")
        print(f"runtime root: fstype={payload['root_fstype']} overlay_active={payload['overlay_active']}")


def cmd_mode_set(args: argparse.Namespace) -> None:
    ensure_root()
    target_mode = args.mode
    value = MODE_TO_VALUE[target_mode]

    targets = mode_target_paths()

    actions = [f'write overlay mode {value!r} into {target}' for target in targets]
    if args.reboot:
        actions.append('reboot system')

    if args.dry_run:
        print('dry-run actions:')
        for item in actions:
            print(f'- {item}')
        return

    if not args.yes:
        print('error: --yes required for mode set (or use --dry-run)', file=sys.stderr)
        sys.exit(2)

    for target in targets:
        write_overlay_local(target, value)
    run(['sync'], check=False)

    print(f"mode set: {target_mode} (overlayroot={value!r})")
    for target in targets:
        print(f"updated: {target}")

    if args.reboot:
        print('rebooting...')
        subprocess.Popen(['systemctl', 'reboot'])


def cmd_backup(args: argparse.Namespace) -> None:
    ensure_root()
    base_dir = Path(args.dest) if args.dest else (Path('/data/backups') if Path('/data').exists() else Path('/home/musicbox/backups'))
    base_dir.mkdir(parents=True, exist_ok=True)

    stamp = dt.datetime.now().strftime('%Y%m%d-%H%M%S')
    outfile = base_dir / f'musicbox-cutover-backup-{stamp}.tar.gz'

    include_paths = [
        Path('/etc/fstab'),
        Path('/etc/overlayroot.conf'),
        Path('/etc/overlayroot.local.conf'),
        Path('/etc/default/musicbox'),
        Path('/etc/systemd/system/musicbox-status.service'),
        Path('/etc/systemd/system/musicbox-status.service.d'),
        Path('/data/config'),
    ]

    with tarfile.open(outfile, 'w:gz') as tar:
        for path in include_paths:
            if path.exists():
                tar.add(path, arcname=str(path).lstrip('/'))

    payload = {'ok': True, 'archive': str(outfile)}
    if args.json:
        print(json.dumps(payload, indent=2, sort_keys=True))
    else:
        print(f"backup created: {outfile}")


def cmd_logs(args: argparse.Namespace) -> None:
    cmd = ['journalctl', '-u', SERVICE_NAME, '-n', str(args.lines), '--no-pager']
    if args.follow:
        cmd.append('-f')
    subprocess.run(cmd, check=False)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog='musicbox', description='Musicbox appliance operations CLI')
    sub = parser.add_subparsers(dest='command', required=True)

    p_status = sub.add_parser('status', help='show operational status')
    p_status.add_argument('--json', action='store_true', help='emit JSON')
    p_status.set_defaults(func=cmd_status)

    p_doctor = sub.add_parser('doctor', help='run health checks for appliance mode')
    p_doctor.add_argument('--json', action='store_true', help='emit JSON')
    p_doctor.set_defaults(func=cmd_doctor)

    p_mode = sub.add_parser('mode', help='get or set overlay mode')
    p_mode_sub = p_mode.add_subparsers(dest='mode_cmd', required=True)

    p_mode_get = p_mode_sub.add_parser('get', help='show configured/runtime mode')
    p_mode_get.add_argument('--json', action='store_true', help='emit JSON')
    p_mode_get.set_defaults(func=cmd_mode_get)

    p_mode_set = p_mode_sub.add_parser('set', help='set appliance/maintenance mode')
    p_mode_set.add_argument('mode', choices=['appliance', 'maintenance'])
    p_mode_set.add_argument('--yes', action='store_true', help='confirm system changes')
    p_mode_set.add_argument('--dry-run', action='store_true', help='show actions only')
    p_mode_set.add_argument('--reboot', action='store_true', help='reboot after setting mode')
    p_mode_set.set_defaults(func=cmd_mode_set)

    p_backup = sub.add_parser('backup', help='create cutover backup archive')
    p_backup.add_argument('--dest', help='destination directory for archive')
    p_backup.add_argument('--json', action='store_true', help='emit JSON')
    p_backup.set_defaults(func=cmd_backup)

    p_logs = sub.add_parser('logs', help='show service logs')
    p_logs.add_argument('-n', '--lines', type=int, default=80, help='tail line count')
    p_logs.add_argument('-f', '--follow', action='store_true', help='follow logs')
    p_logs.set_defaults(func=cmd_logs)

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == '__main__':
    main()
